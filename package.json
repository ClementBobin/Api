{
  "name": "fastify-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "start": "node dist/app.js",
    "dev": "nodemon --watch src src/app.ts",
    "test": "jest",
    "lint": "eslint .",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docker:build": "docker build --platform=linux/amd64 -t myapp:latest -f ./Dockerfile .",
    "docker:run": "docker run -p 3000:3000 --network=api_db_network myapp:latest",
    "types:check": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "postinstall": "prisma generate",
    "seed": "nodemon prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.3",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.4.2",
    "@scalar/fastify-api-reference": "^1.25.116",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.1",
    "prisma": "^6.3.1",
    "ts-node": "^10.9.2",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@jest/globals": "^29.7.0",
    "@prisma/client": "^6.3.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.1",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.20.1",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "nodemon": "^3.1.10",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
