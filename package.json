{
  "name": "next-api-prisma",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "types:check": "tsc --noEmit",
    "docker:build": "docker build --platform=linux/amd64 -t ${image_name} --build-arg=\"BASE_IMAGE=scalar-base\" -f ./Dockerfile .",
    "lint:fix": "next lint --fix"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@scalar/nextjs-api-reference": "^0.5.8",
    "@scalar/nextjs-openapi": "^0.0.35",
    "jest-mock": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "next": "^15.1.7",
    "node-mocks-http": "^1.16.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.6.8",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.20.6",
    "@types/estree": "^1.0.6",
    "@types/jest": "^29.5.14",
    "@types/jest-json-schema": "^6.1.4",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.17.18",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "15.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-json-schema": "^6.1.0",
    "prisma": "^6.3.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
