{
  "name": "express-api",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "test": "jest",
    "lint": "eslint .",
    "build": "tsc --build",
    "start": "node -r tsconfig-paths/register dist/app.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "docker:build": "docker build --platform=linux/amd64 -t myapp:latest -f ./Dockerfile .",
    "docker:run": "docker run -p 3000:3000 myapp:latest",
    "types:check": "tsc --noEmit",
    "lint:fix": "eslint . --fix"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@scalar/express-api-reference": "^0.4.180",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "prisma": "^6.3.1",
    "supertest": "^7.0.0",
    "swagger-jsdoc": "^6.2.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.26.9",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-typescript": "^7.26.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  }
}
