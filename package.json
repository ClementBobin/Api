{
  "name": "express-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "start": "node dist/app.js",
    "dev": "nodemon --watch src src/app.ts",
    "test": "jest",
    "lint": "eslint .",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docker:build": "docker build --platform=linux/amd64 -t myapp:latest -f ./Dockerfile .",
    "docker:run": "docker run -p 3000:3000 myapp:latest",
    "types:check": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "postinstall": "prisma generate",
    "seed": "nodemon prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.2",
    "@prisma/client": "^6.3.1",
    "@scalar/express-api-reference": "^0.4.180",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "prisma": "^6.3.1",
    "tsx": "^4.19.3",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.30",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.28.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.3"
  }
}
