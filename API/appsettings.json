{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {UnixTimestamp}] {Level} {Caller}: {Message}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/logs-.log",
          "rollingInterval": "Month",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {UnixTimestamp}] {Level} {Caller}: {Message}{NewLine}{Exception}"
        }
      }
    ]
  }
}
