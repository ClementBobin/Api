{
  "compilerOptions": {
      "module": "ESNext",
      "moduleResolution": "Node",
      "target": "ESNext",
      "strict": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "allowJs": true,
      "outDir": "./dist"
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
    "exclude": ["node_modules"]
  }
  
