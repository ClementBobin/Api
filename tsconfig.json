{
  "compilerOptions": {
    "target": "es5",                             // Target ECMAScript version
    "module": "commonjs",                        // Module system
    "moduleResolution": "node",                      // Resolve modules like Node.js
    "esModuleInterop": true,                     // Enable commonjs interop
    "skipLibCheck": true,                        // Skip type checking for declaration files
    "strict": true,                              // Enable strict type-checking
    "resolveJsonModule": true,                   // Allow importing JSON files
    "allowJs": true,                             // Allow JavaScript files
    "baseUrl": ".",                              // Base directory for module resolution
    "paths": {                                   // Optional: if you use custom paths
      "@scalar/express-api-reference": ["node_modules/@scalar/express-api-reference/dist/index.d.ts"]
    },                          // Base directory for module resolution
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],     // Include all TypeScript files in the 'src' directory
}
